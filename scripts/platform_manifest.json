{
  "_description": "Canonical platform capability manifest for MCPlayground Core Template. Source of truth for prerequisites, browser defaults, and platform-specific paths.",
  "prerequisites": {
    "required": [
      { "name": "node", "check": "node --version", "version_pattern": "^v(2[0-2])\\.", "min_version": "20.0.0", "install_hint": { "darwin": "brew install node@22", "linux": "curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt-get install -y nodejs", "win32": "winget install OpenJS.NodeJS.LTS" } },
      { "name": "npm", "check": "npm --version", "min_version": "9.0.0", "install_hint": { "darwin": "Bundled with Node.js", "linux": "Bundled with Node.js", "win32": "Bundled with Node.js" } },
      { "name": "python3", "check": "python3 --version", "version_pattern": "Python (3\\.\\d+)", "min_version": "3.9.0", "install_hint": { "darwin": "brew install python@3.12", "linux": "sudo apt-get install -y python3 python3-venv", "win32": "winget install Python.Python.3.12" } },
      { "name": "git", "check": "git --version", "install_hint": { "darwin": "xcode-select --install", "linux": "sudo apt-get install -y git", "win32": "winget install Git.Git" } }
    ],
    "recommended": [
      { "name": "tmux", "check": "tmux -V", "install_hint": { "darwin": "brew install tmux", "linux": "sudo apt-get install -y tmux", "win32": "Not natively supported on Windows; use WSL" }, "note": "Required for ring-leader multi-agent orchestration and office tmux layout" },
      { "name": "curl", "check": "curl --version", "install_hint": { "darwin": "Built-in", "linux": "sudo apt-get install -y curl", "win32": "Built-in on Windows 10+" } },
      { "name": "lsof", "check": "lsof -v", "install_hint": { "darwin": "Built-in on macOS", "linux": "sudo apt-get install -y lsof", "win32": "Not typically available natively on Windows; use WSL or rely on browser-only flows" }, "note": "Needed for truthful office GUI listener checks on Unix hosts" },
      { "name": "ollama", "check": "ollama --version", "install_hint": { "darwin": "brew install ollama", "linux": "curl -fsSL https://ollama.ai/install.sh | sh", "win32": "winget install Ollama.Ollama" }, "note": "Required for local model inference (MLX/llama backends)" }
    ]
  },
  "browsers": {
    "_description": "Default browser detection order per platform. First match wins.",
    "darwin": [
      { "name": "System default", "binary": "open", "open_cmd": ["open"] },
      { "name": "Google Chrome", "app_path": "/Applications/Google Chrome.app", "open_cmd": ["open", "-a", "Google Chrome"] },
      { "name": "Microsoft Edge", "app_path": "/Applications/Microsoft Edge.app", "open_cmd": ["open", "-a", "Microsoft Edge"] },
      { "name": "Firefox", "app_path": "/Applications/Firefox.app", "open_cmd": ["open", "-a", "Firefox"] },
      { "name": "Safari", "app_path": "/Applications/Safari.app", "open_cmd": ["open", "-a", "Safari"] }
    ],
    "linux": [
      { "name": "System default", "binary": "xdg-open", "open_cmd": ["xdg-open"] },
      { "name": "Google Chrome", "binary": "google-chrome", "open_cmd": ["google-chrome"] },
      { "name": "Google Chrome (Stable)", "binary": "google-chrome-stable", "open_cmd": ["google-chrome-stable"] },
      { "name": "Microsoft Edge", "binary": "microsoft-edge", "open_cmd": ["microsoft-edge"] },
      { "name": "Firefox", "binary": "firefox", "open_cmd": ["firefox"] }
    ],
    "win32": [
      { "name": "System default", "binary": "explorer", "open_cmd": ["cmd.exe", "/c", "start", ""] },
      { "name": "Microsoft Edge", "binary": "msedge", "registry_path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\msedge.exe", "program_files_path": "Microsoft\\Edge\\Application\\msedge.exe", "local_app_data_path": "Microsoft\\Edge\\Application\\msedge.exe", "open_cmd": ["cmd.exe", "/c", "start", "msedge"] },
      { "name": "Google Chrome", "binary": "chrome", "registry_path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\chrome.exe", "program_files_path": "Google\\Chrome\\Application\\chrome.exe", "local_app_data_path": "Google\\Chrome\\Application\\chrome.exe", "open_cmd": ["cmd.exe", "/c", "start", "chrome"] },
      { "name": "Google Chrome (Alt)", "binary": "google-chrome", "program_files_path": "Google\\Chrome\\Application\\chrome.exe", "local_app_data_path": "Google\\Chrome\\Application\\chrome.exe", "open_cmd": ["cmd.exe", "/c", "start", "chrome"] },
      { "name": "Firefox", "binary": "firefox", "program_files_path": "Mozilla Firefox\\firefox.exe", "local_app_data_path": "Mozilla Firefox\\firefox.exe", "open_cmd": ["cmd.exe", "/c", "start", "firefox"] }
    ]
  },
  "platforms": {
    "darwin": { "service_manager": "launchd", "shell": "zsh", "node_paths": ["/opt/homebrew/bin/node", "/usr/local/bin/node"] },
    "linux": {
      "service_manager": "systemd",
      "shell": "bash",
      "node_paths": ["/usr/bin/node", "/usr/local/bin/node"],
      "distributions": {
        "ubuntu": { "label": "Ubuntu", "family": "debian" },
        "rocky": { "label": "Rocky Linux", "family": "rhel" },
        "amazon-linux": { "label": "Amazon Linux", "family": "rhel" }
      }
    },
    "win32": { "service_manager": "none", "shell": "powershell", "node_paths": [] }
  },
  "bootstrap_install": {
    "darwin": {
      "manager_label": "Homebrew",
      "manager_check": "brew --version",
      "manager_hint": "Install Homebrew from https://brew.sh before running the automated bootstrap installer on macOS.",
      "commands": {
        "node": "brew install node@22 && brew unlink node >/dev/null 2>&1 || true && brew link --overwrite --force node@22",
        "npm": "npm install -g npm@10.9.4 || sudo npm install -g npm@10.9.4",
        "python3": "brew install python@3.12",
        "git": "xcode-select --install || true",
        "tmux": "brew install tmux",
        "curl": null,
        "lsof": null,
        "ollama": "brew install ollama"
      }
    },
    "linux": {
      "default": {
        "manager_label": "system package manager",
        "manager_check": "sh -lc 'command -v apt-get || command -v dnf || command -v yum'",
        "manager_hint": "Use a supported package manager (apt-get, dnf, or yum) or install the pinned runtimes manually.",
        "commands": {
          "node": "echo 'Install Node.js 22.x with your package manager or NodeSource, then rerun bootstrap.'",
          "npm": "npm install -g npm@10.9.4 || sudo npm install -g npm@10.9.4",
          "python3": "echo 'Install python3 3.12+ with your package manager, then rerun bootstrap.'",
          "git": "echo 'Install git with your package manager, then rerun bootstrap.'",
          "tmux": "echo 'Install tmux with your package manager if you need the full multi-agent terminal layout.'",
          "curl": "echo 'Install curl with your package manager if it is missing.'",
          "lsof": "echo 'Install lsof with your package manager if it is missing.'",
          "ollama": "curl -fsSL https://ollama.ai/install.sh | sh"
        }
      },
      "ubuntu": {
        "manager_label": "apt-get",
        "manager_check": "apt-get --version",
        "manager_hint": "Ubuntu bootstrap install requires apt-get and sudo.",
        "commands": {
          "node": "curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt-get install -y nodejs",
          "npm": "npm install -g npm@10.9.4 || sudo npm install -g npm@10.9.4",
          "python3": "sudo apt-get install -y python3 python3-venv",
          "git": "sudo apt-get install -y git",
          "tmux": "sudo apt-get install -y tmux",
          "curl": "sudo apt-get install -y curl",
          "lsof": "sudo apt-get install -y lsof",
          "ollama": "curl -fsSL https://ollama.ai/install.sh | sh"
        }
      },
      "rocky": {
        "manager_label": "dnf",
        "manager_check": "dnf --version",
        "manager_hint": "Rocky Linux bootstrap install requires dnf and sudo.",
        "commands": {
          "node": "curl -fsSL https://rpm.nodesource.com/setup_22.x | sudo bash - && sudo dnf install -y nodejs",
          "npm": "npm install -g npm@10.9.4 || sudo npm install -g npm@10.9.4",
          "python3": "sudo dnf install -y python3",
          "git": "sudo dnf install -y git",
          "tmux": "sudo dnf install -y tmux",
          "curl": "sudo dnf install -y curl",
          "lsof": "sudo dnf install -y lsof",
          "ollama": "curl -fsSL https://ollama.ai/install.sh | sh"
        }
      },
      "amazon-linux": {
        "manager_label": "dnf",
        "manager_check": "dnf --version",
        "manager_hint": "Amazon Linux bootstrap install requires dnf and sudo.",
        "commands": {
          "node": "curl -fsSL https://rpm.nodesource.com/setup_22.x | sudo bash - && sudo dnf install -y nodejs",
          "npm": "npm install -g npm@10.9.4 || sudo npm install -g npm@10.9.4",
          "python3": "sudo dnf install -y python3",
          "git": "sudo dnf install -y git",
          "tmux": "sudo dnf install -y tmux",
          "curl": "sudo dnf install -y curl",
          "lsof": "sudo dnf install -y lsof",
          "ollama": "curl -fsSL https://ollama.ai/install.sh | sh"
        }
      }
    },
    "win32": {
      "manager_label": "winget",
      "manager_check": "winget --version",
      "manager_hint": "Install the Microsoft App Installer / winget before running automated Windows bootstrap installs.",
      "commands": {
        "node": "winget install --id OpenJS.NodeJS.LTS -e --accept-package-agreements --accept-source-agreements",
        "npm": "npm install -g npm@10.9.4",
        "python3": "winget install --id Python.Python.3.12 -e --accept-package-agreements --accept-source-agreements",
        "git": "winget install --id Git.Git -e --accept-package-agreements --accept-source-agreements",
        "tmux": null,
        "curl": null,
        "lsof": null,
        "ollama": "winget install --id Ollama.Ollama -e --accept-package-agreements --accept-source-agreements"
      }
    }
  },
  "launchers": {
    "office_gui": {
      "darwin": {
        "supported": true,
        "entrypoint": "node ./scripts/agent_office_gui.mjs",
        "service_mode": "launchd-or-runner",
        "required_tools": [],
        "recommended_tools": []
      },
      "linux": {
        "supported": true,
        "entrypoint": "node ./scripts/agent_office_gui.mjs",
        "service_mode": "runner",
        "required_tools": [],
        "recommended_tools": []
      },
      "win32": {
        "supported": true,
        "entrypoint": "node ./scripts/agent_office_gui.mjs",
        "service_mode": "runner",
        "required_tools": [],
        "recommended_tools": []
      }
    },
    "agentic_suite": {
      "darwin": {
        "supported": true,
        "entrypoint": "node ./scripts/agentic_suite_launch.mjs",
        "service_mode": "launchd-or-runner",
        "visible_surface": "apps-browser-status",
        "required_tools": [],
        "recommended_tools": [],
        "apps": {
          "Codex": [
            { "app_name": "Codex", "app_path": "/Applications/Codex.app" }
          ],
          "Cursor": [
            { "app_name": "Cursor", "app_path": "/Applications/Cursor.app" }
          ],
          "Claude": [
            { "app_name": "Claude", "app_path": "/Applications/Claude.app" }
          ]
        }
      },
      "linux": {
        "supported": true,
        "entrypoint": "node ./scripts/agentic_suite_launch.mjs",
        "service_mode": "runner",
        "visible_surface": "apps-browser-status",
        "supported_distributions": ["ubuntu", "rocky", "amazon-linux"],
        "required_tools": [],
        "recommended_tools": [],
        "apps": {
          "Codex": [
            { "binary": "codex" }
          ],
          "Cursor": [
            { "binary": "cursor" }
          ],
          "Claude": [
            { "binary": "claude" }
          ]
        }
      },
      "win32": {
        "supported": true,
        "entrypoint": "node ./scripts/agentic_suite_launch.mjs",
        "service_mode": "runner",
        "visible_surface": "apps-browser-status",
        "required_tools": [],
        "recommended_tools": [],
        "apps": {
          "Codex": [
            { "binary": "codex" }
          ],
          "Cursor": [
            {
              "binary": "cursor",
              "program_files_path": "Cursor\\Cursor.exe",
              "local_app_data_path": "Programs\\Cursor\\Cursor.exe"
            }
          ],
          "Claude": [
            { "binary": "claude" }
          ]
        }
      }
    }
  }
}
