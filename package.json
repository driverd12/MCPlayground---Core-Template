    "providers:install": "node ./scripts/run_sh.mjs ./scripts/provider_bridge.sh install",
    "dell:r450:doctor": "node ./scripts/run_sh.mjs ./scripts/dell_serial_doctor.sh",
    "dell:r450:serial": "node ./scripts/run_sh.mjs ./scripts/dell_r450_serial_console.sh",
    "dell:r450:ssh": "node ./scripts/run_sh.mjs ./scripts/dell_r450_ssh_ready.sh",
    "production:doctor": "node ./scripts/run_sh.mjs ./scripts/production_readiness.sh",
    "codex:mcp:register": "node ./scripts/run_sh.mjs ./scripts/codex_mcp_register.sh",
    "doctor": "node ./scripts/bootstrap_doctor.mjs",
    "doctor:bootstrap": "node ./scripts/bootstrap_doctor.mjs",
    "doctor:macos:authority": "node ./scripts/macos_authority_audit.mjs",
    "local:training:status": "node ./scripts/local_adapter_lane.mjs status",
