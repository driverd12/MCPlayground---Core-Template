{
  "name": "mcplayground-core-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && npm run test:python && node --test ./tests/auto_squish.persistence.test.mjs ./tests/core_template.integration.test.mjs ./tests/storage_guard.persistence.test.mjs ./tests/agentic_pack.integration.test.mjs ./tests/trichat_auto_retention.persistence.test.mjs ./tests/trichat_autopilot.persistence.test.mjs ./tests/trichat_autopilot.snappiness.test.mjs ./tests/trichat_autopilot.tmux_backend.test.mjs ./tests/trichat_bus.unixsocket.test.mjs ./tests/trichat_tmux_controller.test.mjs ./tests/worker_fabric_and_benchmark.test.mjs ./tests/next_wave_runtime.integration.test.mjs ./tests/autonomy_bootstrap.integration.test.mjs ./tests/autonomy_command.integration.test.mjs ./tests/autonomy_ide_ingress.integration.test.mjs ./tests/autonomy_shell_wrappers.integration.test.mjs ./tests/autonomy_http_startup.integration.test.mjs ./tests/provider_bridge.integration.test.mjs",
    "test:python": "PYTHONWARNINGS=ignore::ResourceWarning python3 -m unittest discover -s bridges -p 'test_*.py' && python3 -m unittest discover -s tests -p 'test_*.py'",
    "test:bridges": "npm run test:python",
    "start": "node dist/server.js",
    "start:stdio": "node dist/server.js",
    "start:http": "MCP_HTTP=1 node dist/server.js --http --http-port 8787",
    "start:core": "MCP_DOMAIN_PACKS=none node dist/server.js",
    "start:core:http": "MCP_HTTP=1 MCP_DOMAIN_PACKS=none node dist/server.js --http --http-port 8787",
    "agentic:micro-soak": "npm run build && node ./scripts/agentic_micro_soak.mjs",
    "inbox:worker": "python3 ./scripts/imprint_inbox_worker.py --repo-root .",
    "inbox:enqueue": "node ./scripts/inbox_enqueue.mjs",
    "mvp:smoke": "./scripts/mvp_smoke.sh",
    "trichat": "python3 ./scripts/trichat.py",
    "trichat:http": "TRICHAT_MCP_TRANSPORT=http python3 ./scripts/trichat.py --transport http --url http://127.0.0.1:8787/ --origin http://127.0.0.1 --resume-latest --panel-on-start",
    "trichat:tui": "./scripts/trichat_tui_launch.sh --transport stdio",
    "trichat:tui:http": "./scripts/trichat_tui_launch.sh --transport http",
    "trichat:office": "python3 ./scripts/agent_office_dashboard.py --resume-latest --view office",
    "trichat:office:http": "TRICHAT_MCP_TRANSPORT=http python3 ./scripts/agent_office_dashboard.py --resume-latest --view office --transport http --url http://127.0.0.1:8787/ --origin http://127.0.0.1",
    "trichat:office:tmux": "./scripts/agent_office_tmux.sh",
    "trichat:app:install": "./scripts/install_trichat_app.sh",
    "trichat:roster": "node ./scripts/trichat_roster.mjs",
    "trichat:doctor": "./scripts/trichat_doctor.sh",
    "trichat:bridges:test": "npm run test:bridges",
    "trichat:smoke": "./scripts/trichat_smoke.sh",
    "trichat:dogfood": "node ./scripts/trichat_dogfood.mjs",
    "trichat:soak:gate": "node ./scripts/trichat_soak_gate.mjs",
    "trichat:reliability": "./scripts/trichat_reliability_ctl.sh",
    "it:http:validate": "./scripts/it_local_http_validate.sh",
    "imprint:bootstrap": "./scripts/imprint_bootstrap.sh",
    "launchd:install": "./scripts/launchd_install.sh",
    "launchd:uninstall": "./scripts/launchd_uninstall.sh",
    "replication:export": "./scripts/export_replication_bundle.sh",
    "agents:on": "./scripts/agents_switch.sh on",
    "agents:off": "./scripts/agents_switch.sh off",
    "agents:status": "./scripts/agents_switch.sh status",
    "ring-leader:cleanup": "./scripts/ring_leader_cleanup.sh",
    "ring-leader:status": "./scripts/ring_leader_ctl.sh status",
    "ring-leader:start": "./scripts/ring_leader_ctl.sh start",
    "ring-leader:stop": "./scripts/ring_leader_ctl.sh stop",
    "ring-leader:run": "./scripts/ring_leader_ctl.sh run_once",
    "autonomy:status": "./scripts/autonomy_ctl.sh status",
    "autonomy:ensure": "./scripts/autonomy_ctl.sh ensure",
    "autonomy:maintain": "./scripts/autonomy_ctl.sh maintain",
    "autonomy:intake": "./scripts/autonomy_command.sh",
    "autonomy:command": "./scripts/autonomy_command.sh",
    "autonomy:ide": "./scripts/autonomy_ide_ingress.sh",
    "autonomy:ingress": "./scripts/autonomy_ide_ingress.sh",
    "autonomy:intake:shell": "./scripts/autonomy_intake_shell.sh",
    "providers:status": "./scripts/provider_bridge.sh status",
    "providers:export": "./scripts/provider_bridge.sh export",
    "providers:install": "./scripts/provider_bridge.sh install",
    "production:doctor": "./scripts/production_readiness.sh",
    "codex:mcp:register": "./scripts/codex_mcp_register.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}
