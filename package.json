    "autonomy:maintain": "node ./scripts/run_sh.mjs ./scripts/autonomy_ctl.sh maintain",
    "autonomy:intake": "node ./scripts/run_sh.mjs ./scripts/autonomy_command.sh",
    "autonomy:command": "node ./scripts/run_sh.mjs ./scripts/autonomy_command.sh",
    "autonomy:ide": "node ./scripts/run_sh.mjs ./scripts/autonomy_ide_ingress.sh",
    "autonomy:ingress": "node ./scripts/run_sh.mjs ./scripts/autonomy_ide_ingress.sh",
    "autonomy:intake:shell": "node ./scripts/run_sh.mjs ./scripts/autonomy_intake_shell.sh",
    "brief:current": "node ./scripts/run_sh.mjs ./scripts/operator_brief.sh",
