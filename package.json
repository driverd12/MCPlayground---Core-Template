{
  "name": "mcplayground-core-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test ./tests/auto_squish.persistence.test.mjs ./tests/core_template.integration.test.mjs ./tests/storage_guard.persistence.test.mjs ./tests/cfd_pack.integration.test.mjs ./tests/trichat_auto_retention.persistence.test.mjs ./tests/trichat_autopilot.persistence.test.mjs ./tests/trichat_autopilot.snappiness.test.mjs ./tests/trichat_autopilot.tmux_backend.test.mjs ./tests/trichat_bus.unixsocket.test.mjs ./tests/trichat_tmux_controller.test.mjs",
    "start": "node dist/server.js",
    "start:stdio": "node dist/server.js",
    "start:http": "MCP_HTTP=1 node dist/server.js --http --http-port 8787",
    "start:cfd": "MCP_DOMAIN_PACKS=cfd node dist/server.js",
    "start:cfd:http": "MCP_HTTP=1 MCP_DOMAIN_PACKS=cfd node dist/server.js --http --http-port 8787",
    "inbox:worker": "python3 ./scripts/imprint_inbox_worker.py --repo-root .",
    "inbox:enqueue": "node ./scripts/inbox_enqueue.mjs",
    "mvp:smoke": "./scripts/mvp_smoke.sh",
    "trichat:smoke": "./scripts/trichat_smoke.sh",
    "trichat:dogfood": "node ./scripts/trichat_dogfood.mjs",
    "trichat:soak:gate": "node ./scripts/trichat_soak_gate.mjs",
    "trichat:reliability": "./scripts/trichat_reliability_ctl.sh",
    "imprint:bootstrap": "./scripts/imprint_bootstrap.sh",
    "launchd:install": "./scripts/launchd_install.sh",
    "launchd:uninstall": "./scripts/launchd_uninstall.sh",
    "agents:on": "./scripts/agents_switch.sh on",
    "agents:off": "./scripts/agents_switch.sh off",
    "agents:status": "./scripts/agents_switch.sh status"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}
