    "agentic:suite:app:install": "node ./scripts/run_sh.mjs ./scripts/install_agentic_suite_app.sh",
    "mcagent:reset-password": "node ./scripts/run_sh.mjs ./scripts/reset_mcagent_password.sh",
    "trichat:roster": "node ./scripts/trichat_roster.mjs",
    "trichat:doctor": "node ./scripts/run_sh.mjs ./scripts/trichat_doctor.sh",
    "mlx:setup": "node ./scripts/run_sh.mjs ./scripts/mlx_local_backend_setup.sh",
    "ollama:mlx:preview": "node ./scripts/ollama_mlx_preview_setup.mjs",
    "ollama:mlx:postpull": "node ./scripts/ollama_mlx_postpull.mjs --wait",
    "trichat:bridges:test": "npm run test:bridges",
    "trichat:smoke": "node ./scripts/run_sh.mjs ./scripts/trichat_smoke.sh",
