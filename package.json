{
  "name": "mcplayground-core-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bootstrap:env": "node ./scripts/bootstrap_env.mjs",
