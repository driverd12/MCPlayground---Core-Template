    "test:bridges": "npm run test:python",
    "start": "node dist/server.js",
    "start:stdio": "node dist/server.js",
    "start:http": "node ./scripts/run_env.mjs MCP_HTTP=1 -- node dist/server.js --http --http-port 8787",
    "start:core": "node ./scripts/run_env.mjs MCP_DOMAIN_PACKS=none -- node dist/server.js",
    "start:core:http": "node ./scripts/run_env.mjs MCP_HTTP=1 MCP_DOMAIN_PACKS=none -- node dist/server.js --http --http-port 8787",
