    "trichat:office:http": "node ./scripts/run_env.mjs TRICHAT_MCP_TRANSPORT=http -- python3 ./scripts/agent_office_dashboard.py --resume-latest --view office --transport http --url http://127.0.0.1:8787/ --origin http://127.0.0.1",
