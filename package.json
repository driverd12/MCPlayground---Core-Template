{
  "name": "anamnesis",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test ./tests/*.test.mjs",
    "start": "node dist/server.js",
    "start:stdio": "node dist/server.js",
    "start:http": "MCP_HTTP=1 node dist/server.js --http --http-port 8787",
    "inbox:worker": "python3 ./scripts/imprint_inbox_worker.py --repo-root .",
    "inbox:enqueue": "node ./scripts/inbox_enqueue.mjs",
    "mvp:smoke": "./scripts/mvp_smoke.sh",
    "imprint:bootstrap": "./scripts/imprint_bootstrap.sh",
    "launchd:install": "./scripts/launchd_install.sh",
    "launchd:install:reliability": "ANAMNESIS_TRICHAT_RELIABILITY_LOOP_ENABLED=true ./scripts/launchd_install.sh",
    "launchd:uninstall": "./scripts/launchd_uninstall.sh",
    "agents:on": "./scripts/agents_switch.sh on",
    "agents:off": "./scripts/agents_switch.sh off",
    "agents:status": "./scripts/agents_switch.sh status",
    "trichat": "python3 ./scripts/trichat.py",
    "trichat:http": "TRICHAT_MCP_TRANSPORT=http python3 ./scripts/trichat.py --transport http --url http://127.0.0.1:8787/ --origin http://127.0.0.1 --resume-latest --panel-on-start",
    "trichat:tui": "go run ./cmd/trichat-tui --resume-latest",
    "trichat:tui:http": "TRICHAT_MCP_TRANSPORT=http go run ./cmd/trichat-tui --transport http --url http://127.0.0.1:8787/ --origin http://127.0.0.1 --resume-latest",
    "trichat:app:install": "./scripts/install_trichat_app.sh",
    "trichat:bus:status": "python3 ./bridges/trichat_bus_client.py status",
    "trichat:bus:tail": "python3 ./bridges/trichat_bus_client.py tail --limit 50",
    "trichat:bridges:doctor": "python3 ./bridges/bridge_doctor.py",
    "trichat:smoke": "./scripts/trichat_smoke.sh",
    "trichat:dogfood": "./scripts/trichat_dogfood.sh",
    "trichat:dogfood:smoke": "./scripts/trichat_dogfood_smoke.sh",
    "trichat:soak:gate": "node ./scripts/trichat_soak_gate.mjs",
    "trichat:reliability:run_once": "./scripts/trichat_reliability_run_once.sh",
    "trichat:reliability:status": "./scripts/trichat_reliability_ctl.sh status",
    "trichat:reliability:start": "./scripts/trichat_reliability_ctl.sh start",
    "trichat:reliability:stop": "./scripts/trichat_reliability_ctl.sh stop",
    "imprint:math:smoke": "./scripts/imprint_math_smoke.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}
