ANAMNESIS_HUB_DB_PATH=./data/hub.sqlite
# MCP_HUB_DB_PATH=./data/hub.sqlite
MCP_HTTP_BEARER_TOKEN=change-me
MCP_HTTP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
TRICHAT_BUS_SOCKET_PATH=./data/trichat.bus.sock
# TRICHAT_BUS_AUTOSTART=true
# TRICHAT_ADAPTER_HANDSHAKE_TTL_SECONDS=120
# TRICHAT_ADAPTER_RETRY_ATTEMPTS=1
# TRICHAT_ADAPTER_CIRCUIT_THRESHOLD=2
# TRICHAT_ADAPTER_CIRCUIT_RECOVERY_SECONDS=45
# TRICHAT_ADAPTIVE_TIMEOUTS=true
# TRICHAT_ADAPTIVE_TIMEOUT_MIN_SAMPLES=12
# TRICHAT_ADAPTIVE_TIMEOUT_MAX_STEP_SECONDS=8
# TRICHAT_INTEROP_ROUNDS=1
# TRICHAT_COUNCIL_STRIP_MODE=auto
# TRICHAT_COUNCIL_MAX_ROUNDS=5
# TRICHAT_COUNCIL_LATENCY_BUDGET_SECONDS=45
# TRICHAT_COUNCIL_MIN_NOVELTY_DELTA=0.05
# ANAMNESIS_TRICHAT_RELIABILITY_LOOP_ENABLED=false
# ANAMNESIS_TRICHAT_RELIABILITY_INTERVAL_SECONDS=300
# ANAMNESIS_TRICHAT_RELIABILITY_THREAD_ID=trichat-reliability-internal
# ANAMNESIS_TRICHAT_RELIABILITY_DRY_RUN=true
# ANAMNESIS_TRICHAT_RELIABILITY_EXECUTE=false
# Optional soak gate defaults for long-run release checks:
# TRICHAT_SOAK_CYCLE_RETRY_LIMIT=2
# TRICHAT_SOAK_QUORUM_FAILURE_EXTRA_RETRIES=4
# TRICHAT_SOAK_TIMEOUT_FAILURE_EXTRA_RETRIES=2
# TRICHAT_SOAK_BRIDGE_FAILURE_EXTRA_RETRIES=3
# TRICHAT_SOAK_TURN_SETTLE_EXTRA_RETRIES=2
# TRICHAT_SOAK_MAX_CYCLE_ATTEMPTS=12
# TRICHAT_SOAK_ADAPTIVE_CYCLE_TIMEOUTS=true
# TRICHAT_SOAK_WORKBOARD_SETTLE_SECONDS=12
# TRICHAT_SOAK_WORKBOARD_SETTLE_MAX_SECONDS=180
# Optional client defaults for trichat.autopilot payloads:
# ANAMNESIS_TRICHAT_AUTOPILOT_MODE=normal
# ANAMNESIS_TRICHAT_AUTOPILOT_INTERVAL_SECONDS=300
# ANAMNESIS_TRICHAT_AUTOPILOT_THREAD_ID=trichat-autopilot-internal
# ANAMNESIS_TRICHAT_AUTOPILOT_THREAD_STATUS=archived
