ANAMNESIS_HUB_DB_PATH=./data/hub.sqlite
# MCP_HUB_DB_PATH=./data/hub.sqlite

# Startup DB guardrails (recommended)
# ANAMNESIS_HUB_RUN_QUICK_CHECK_ON_START=1
# ANAMNESIS_HUB_STARTUP_BACKUP=1
# ANAMNESIS_HUB_BACKUP_DIR=./data/backups
# ANAMNESIS_HUB_BACKUP_KEEP=6
# ANAMNESIS_HUB_BACKUP_MAX_TOTAL_BYTES=103079215104
# ANAMNESIS_HUB_BACKUP_MIN_INTERVAL_SECONDS=21600
# ANAMNESIS_HUB_AUTO_RESTORE_FROM_BACKUP=1
# ANAMNESIS_HUB_ALLOW_FRESH_DB_ON_CORRUPTION=0

MCP_HTTP_BEARER_TOKEN=change-me
MCP_HTTP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8787

# Enable one or more built-in domain packs (comma-separated).
# Leave empty for core-only runtime.
# MCP_DOMAIN_PACKS=
# MCP_DOMAIN_PACKS=cfd

# Optional launchd/inbox defaults
# ANAMNESIS_IMPRINT_PROFILE_ID=default
# ANAMNESIS_INBOX_POLL_INTERVAL=5
# ANAMNESIS_INBOX_BATCH_SIZE=3
# ANAMNESIS_INBOX_LEASE_SECONDS=300
# ANAMNESIS_INBOX_HEARTBEAT_INTERVAL=30

# TriChat bridge adapter overrides (optional)
# TRICHAT_CODEX_CMD=python3 bridges/codex_bridge.py
# TRICHAT_CURSOR_CMD=python3 bridges/cursor_bridge.py
# TRICHAT_IMPRINT_CMD=python3 bridges/local_imprint_bridge.py
# TRICHAT_RING_LEADER_CMD=python3 bridges/local_imprint_bridge.py
# TRICHAT_IMPLEMENTATION_DIRECTOR_CMD=python3 bridges/local_imprint_bridge.py
# TRICHAT_RESEARCH_DIRECTOR_CMD=python3 bridges/local_imprint_bridge.py
# TRICHAT_VERIFICATION_DIRECTOR_CMD=python3 bridges/local_imprint_bridge.py
# TRICHAT_CODE_SMITH_CMD=python3 bridges/local_imprint_bridge.py
# TRICHAT_RESEARCH_SCOUT_CMD=python3 bridges/local_imprint_bridge.py
# TRICHAT_QUALITY_GUARD_CMD=python3 bridges/local_imprint_bridge.py
# TRICHAT_SPECIALIST_MODEL=llama3.2:3b
# TRICHAT_RING_LEADER_MODEL=llama3.2:3b
# TRICHAT_IMPLEMENTATION_DIRECTOR_MODEL=llama3.2:3b
# TRICHAT_RESEARCH_DIRECTOR_MODEL=llama3.2:3b
# TRICHAT_VERIFICATION_DIRECTOR_MODEL=llama3.2:3b
# TRICHAT_CODE_SMITH_MODEL=llama3.2:3b
# TRICHAT_RESEARCH_SCOUT_MODEL=llama3.2:3b
# TRICHAT_QUALITY_GUARD_MODEL=llama3.2:3b
# TRICHAT_LOCAL_INFERENCE_PROVIDER=auto
# TRICHAT_MLX_PYTHON=/absolute/path/to/.venv-mlx/bin/python
# TRICHAT_MLX_MODEL=mlx-community/Qwen2.5-Coder-3B-Instruct-4bit
# TRICHAT_MLX_ENDPOINT=http://127.0.0.1:8788
# TRICHAT_MLX_SERVER_ENABLED=1

# TriChat bus/runtime defaults (optional)
# TRICHAT_BUS_SOCKET_PATH=./data/trichat.bus.sock
# TRICHAT_BUS_AUTOSTART=1
# TRICHAT_VERIFY_COMMAND=
# TRICHAT_VERIFY_TIMEOUT_SECONDS=90

# TriChat tmux controller defaults
# TRICHAT_TMUX_BIN=tmux
# TRICHAT_TMUX_DRY_RUN=0

# TriChat TUI interactive execute routing defaults
# TRICHAT_AUTO_EXECUTE_AFTER_DECISION=0
# TRICHAT_AUTO_EXECUTE_CYCLES=2
# TRICHAT_AUTO_EXECUTE_BREAKER_FAILURES=2
# TRICHAT_EXECUTE_BACKEND=auto
# TRICHAT_TMUX_SESSION_NAME=trichat-live
# TRICHAT_TMUX_WORKER_COUNT=3
# TRICHAT_TMUX_MAX_QUEUE_PER_WORKER=8
# TRICHAT_TMUX_SYNC_AFTER_DISPATCH=1
# TRICHAT_TMUX_LOCK_LEASE_SECONDS=600

# TriChat autopilot tmux execution defaults (overridable per tool call)
# execute_backend: direct|tmux|auto
# TRICHAT_AUTOPILOT_EXECUTE_BACKEND=auto
# TRICHAT_AUTOPILOT_TMUX_SESSION=trichat-autopilot
# TRICHAT_AUTOPILOT_TMUX_WORKERS=3

# Ring leader self-starter defaults
# TRICHAT_RING_LEADER_AUTOSTART=1
# TRICHAT_RING_LEADER_AGENT_ID=ring-leader
# TRICHAT_RING_LEADER_SPECIALIST_AGENT_IDS=implementation-director,research-director,verification-director,local-imprint,codex
# TRICHAT_RING_LEADER_AWAY_MODE=normal
# TRICHAT_RING_LEADER_INTERVAL_SECONDS=180
# TRICHAT_RING_LEADER_THREAD_ID=ring-leader-main
# TRICHAT_RING_LEADER_THREAD_TITLE=Ring Leader Main Loop
# TRICHAT_RING_LEADER_THREAD_STATUS=active
# TRICHAT_RING_LEADER_OBJECTIVE=Inspect kernel state, choose one bounded next action, and delegate specialist work.
# TRICHAT_RING_LEADER_EXECUTE_BACKEND=auto
# TRICHAT_RING_LEADER_CONFIDENCE_THRESHOLD=0.45
